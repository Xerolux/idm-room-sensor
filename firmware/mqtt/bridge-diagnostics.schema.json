{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Xerolux/IDM-Smart-Climate-Platform/blob/main/firmware/mqtt/bridge-diagnostics.schema.json",
  "title": "IDM analog bridge diagnostics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "device",
    "mode",
    "bridge_state",
    "bridge_error",
    "safe_active",
    "stale",
    "fault",
    "output_ready",
    "effective_humidity",
    "effective_temperature",
    "command_source",
    "command_quality",
    "output_fault",
    "output_error",
    "humidity_dac_code",
    "temperature_digipot_code",
    "target_resistance_ohm",
    "calibration_status",
    "calibration_version",
    "calibration_using_factory",
    "uptime_s"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "device": {"type": "string", "minLength": 1},
    "mode": {"const": "analog_bridge"},
    "bridge_state": {"type": "string"},
    "bridge_error": {"type": "string"},
    "safe_active": {"type": "boolean"},
    "stale": {"type": "boolean"},
    "fault": {"type": "boolean"},
    "output_ready": {"type": "boolean"},
    "effective_humidity": {"type": "number", "minimum": 0, "maximum": 100},
    "effective_temperature": {"type": "number", "minimum": -20, "maximum": 60},
    "command_source": {"type": "string"},
    "command_quality": {"type": "number", "minimum": 0, "maximum": 100},
    "output_fault": {"type": "boolean"},
    "output_error": {"type": "string"},
    "humidity_dac_code": {"type": "number", "minimum": 0, "maximum": 4095},
    "temperature_digipot_code": {"type": "number", "minimum": 0, "maximum": 255},
    "target_resistance_ohm": {
      "type": ["number", "null"],
      "minimum": 100,
      "maximum": 50000
    },
    "calibration_status": {"type": "string"},
    "calibration_version": {"type": "number", "minimum": 0, "maximum": 2},
    "calibration_using_factory": {"type": "boolean"},
    "uptime_s": {"type": ["number", "null"], "minimum": 0}
  }
}
