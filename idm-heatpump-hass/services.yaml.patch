set_external_climate:
  name: Set external climate
  description: Write validated external room temperature and/or GLT humidity values.
  target:
    entity:
      integration: idm_heatpump
  fields:
    heating_circuit:
      required: true
      selector:
        select:
          options: [A, B, C, D, E, F, G]
    room_temperature:
      selector:
        number: {min: -20, max: 60, step: 0.1, unit_of_measurement: "°C"}
    humidity:
      selector:
        number: {min: 0, max: 100, step: 0.1, unit_of_measurement: "%"}
    acknowledge_risk:
      required: true
      selector:
        constant: {value: true}
